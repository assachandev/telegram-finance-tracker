# Telegram — get token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Data storage
# Docker: path on HOST machine where finance.db will be stored (e.g. a NAS mount)
# Non-Docker: leave unset to use ./data/ locally
HOST_DATA_DIR=/path/to/your/data/directory

# Currency symbol displayed in all reports (e.g. $ £ € ¥ ₿ ₭ ฿)
CURRENCY_SYMBOL=฿
